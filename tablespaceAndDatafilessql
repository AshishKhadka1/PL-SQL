        -- CREATE A USER IN PDB (PLUGGABLE DABATABASE

-- CHECK CONTAINER
SHOW CON_NAME;

SHOW PDBS;

-- SWITCH TO PDB (COMMONLY XEPDB1 IN ORACLE XE)
ALTER SESSION SET CONTAINER = XEPDB1;

SHOW CON_NAME;

-- CHECK IF USER ALREADY EXISTS
SELECT USERNAME
FROM DBA_USERS
WHERE USERNAME = 'ASHISH';

-- CREATE USER
CREATE USER ASHISH
IDENTIFIED BY ASHISH
DEFAULT TABLESPACE USERS
TEMPORARY TABLESPACE TEMP
QUOTA UNLIMITED ON USERS;

-- CREATE ROLE
CREATE ROLE DEMO;

-- GRANT PRIVILEGES TO ROLE
GRANT CREATE SESSION,
      CREATE TABLE,
      CREATE VIEW,
      CREATE SEQUENCE,
      CREATE PROCEDURE,
      CREATE TRIGGER
TO DEMO;

-- ASSIGN ROLE TO USER
GRANT DEMO TO ASHISH;

-- VERIFY USER
SELECT USERNAME
FROM DBA_USERS
WHERE USERNAME = 'ASHISH';

-- VERIFY ROLE
SELECT ROLE
FROM DBA_ROLES
WHERE ROLE = 'DEMO';

-- VERIFY ROLE ASSIGNED TO USER
SELECT *
FROM DBA_ROLE_PRIVS
WHERE GRANTEE = 'ASHISH';

-- VERIFY PRIVILEGES GRANTED TO ROLE
SELECT *
FROM ROLE_SYS_PRIVS
WHERE ROLE = 'DEMO';

